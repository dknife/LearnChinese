    { "speaker": "A", "variants": [
      { "latin": "Libentissime! Iter nostrum memorabile erit!", "pronunciation": "리벤티시메! 이테르 노스트룸 메모라빌레 에릿!", "korean": "기꺼이! 우리 여행은 기억에 남을 거야!" },
      { "latin": "Maxime volo! Praeparemus nos!", "pronunciation": "막시메 볼로! 프라에파레무스 노스!", "korean": "정말 가고 싶어! 준비하자!" },
      { "latin": "Optime! Amicitia nostra semper durabit!", "pronunciation": "옵티메! 아미키티아 노스트라 셈페르 두라빗!", "korean": "훌륭해! 우리 우정은 영원할 거야!" }
