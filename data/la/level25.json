  "conversations": [
    { "speaker": "A", "variants": [
      { "latin": "Salve, amice! Diu te non vidi!", "pronunciation": "살베, 아미케! 디우 테 논 비디!", "korean": "안녕, 친구! 오랜만이야!" },
      { "latin": "Ave! Quomodo te habuisti?", "pronunciation": "아베! 쿠오모도 테 하부이스티?", "korean": "안녕! 그동안 어떻게 지냈어?" },
      { "latin": "Tandem te video! Ubi fuisti?", "pronunciation": "탄뎀 테 비데오! 우비 푸이스티?", "korean": "드디어 만났다! 어디 있었어?" }
    ]},
    { "speaker": "B", "variants": [
      { "latin": "Salve! In Graecia fui. Iter longum feci.", "pronunciation": "살베! 인 그라에키아 푸이. 이테르 롱굼 페키.", "korean": "안녕! 그리스에 있었어. 긴 여행을 했어." },
      { "latin": "Ave! Per multas terras peregrinavi.", "pronunciation": "아베! 페르 물타스 테라스 페레그리나비.", "korean": "안녕! 여러 나라를 여행했어." },
      { "latin": "In Aegyptum navigavi. Res mirabiles vidi.", "pronunciation": "인 아에깁툼 나비가비. 레스 미라빌레스 비디.", "korean": "이집트로 항해했어. 놀라운 것들을 봤어." }
    ]},
    { "speaker": "A", "variants": [
      { "latin": "Narra mihi de itinere tuo!", "pronunciation": "나라 미히 데 이티네레 투오!", "korean": "여행에 대해 이야기해줘!" },
