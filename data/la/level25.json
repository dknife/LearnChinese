      { "latin": "Qualia loca visitavisti?", "pronunciation": "쿠알리아 로카 비시타비스티?", "korean": "어떤 장소를 방문했어?" }
    ]},
    { "speaker": "B", "variants": [
      { "latin": "Athenas vidi et in Acropoli fui.", "pronunciation": "아테나스 비디 에트 인 아크로폴리 푸이.", "korean": "아테네를 보고 아크로폴리스에 갔어." },
      { "latin": "Pyramides Aegypti magnificae sunt!", "pronunciation": "피라미데스 아에깁티 마그니피카에 순트!", "korean": "이집트의 피라미드는 웅장해!" },
      { "latin": "Homines benigni erant et cibus optimus.", "pronunciation": "호미네스 베니그니 에란트 에트 키부스 옵티무스.", "korean": "사람들은 친절했고 음식은 최고였어." }
    ]},
    { "speaker": "A", "variants": [
      { "latin": "Mirabilia narras! Ego quoque peregrinari volo.", "pronunciation": "미라빌리아 나라스! 에고 쿠오쿠에 페레그리나리 볼로.", "korean": "놀라운 이야기네! 나도 여행하고 싶어." },
      { "latin": "Invidiam tibi fateor! Quando iterum ibis?", "pronunciation": "인비디암 티비 파테오르! 쿠안도 이테룸 이비스?", "korean": "부럽다! 언제 다시 갈 거야?" },
      { "latin": "Valde te fortunatum puto!", "pronunciation": "발데 테 포르투나툼 푸토!", "korean": "정말 운이 좋다고 생각해!" }
    ]},
    { "speaker": "B", "variants": [
      { "latin": "Proximo vere iterum proficiscar. Visne mecum venire?", "pronunciation": "프록시모 베레 이테룸 프로피키스카르. 비스네 메쿰 베니레?", "korean": "다음 봄에 다시 떠날 거야. 나와 함께 갈래?" },
      { "latin": "Mense Maio navigabo. Veni mecum!", "pronunciation": "멘세 마이오 나비가보. 베니 메쿰!", "korean": "5월에 항해할 거야. 같이 가자!" },
      { "latin": "Eamus una! Comites optimi erimus.", "pronunciation": "에아무스 우나! 코미테스 옵티미 에리무스.", "korean": "함께 가자! 좋은 동반자가 될 거야." }
