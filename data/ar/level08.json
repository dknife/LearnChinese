        },
        {
          "arabic": "متى يفتح المتجر؟",
          "romanization": "Matā yaftaḥ al-matjar?",
          "korean": "가게가 몇 시에 열어요?"
        },
        {
          "arabic": "متى يبدأ الفيلم؟",
          "romanization": "Matā yabda' al-fīlm?",
          "korean": "영화가 몇 시에 시작해요?"
        }
      ]
    },
    {
      "speaker": "B",
      "variants": [
        {
          "arabic": "الساعة الثانية والنصف.",
