          "korean": "2시 반이에요."
        },
        {
          "arabic": "يفتح في الساعة التاسعة صباحاً.",
          "romanization": "Yaftaḥ fī as-sāʿa at-tāsiʿa ṣabāḥan.",
          "korean": "아침 9시에 열어요."
        },
        {
          "arabic": "يبدأ في الساعة السابعة مساءً.",
          "romanization": "Yabda' fī as-sāʿa as-sābiʿa masā'an.",
          "korean": "저녁 7시에 시작해요."
        }
      ]
    },
    {
      "speaker": "A",
      "variants": [
        {
          "arabic": "متى ينتهي العمل؟",
