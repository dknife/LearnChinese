      ]
    },
    {
      "speaker": "B",
      "variants": [
        {
          "arabic": "ينتهي في الساعة الخامسة.",
          "romanization": "Yantahī fī as-sāʿa al-khāmisa.",
          "korean": "5시에 끝나요."
        },
        {
          "arabic": "نعم، لدينا ساعة كاملة.",
          "romanization": "Naʿam, ladaynā sāʿa kāmila.",
          "korean": "네, 한 시간 있어요."
        },
        {
          "arabic": "بقي عشر دقائق فقط!",
          "romanization": "Baqiya ʿashr daqā'iq faqaṭ!",
          "korean": "10분밖에 안 남았어요!"
        }
      ]
    },
    {
      "speaker": "A",
      "variants": [
        {
          "arabic": "في أي وقت نلتقي غداً؟",
