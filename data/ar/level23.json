          "korean": "물론이죠, 오늘 끝나기 전에 보낼게요."
        },
        {
          "arabic": "تحدث مع المدير. ستحتاج إلى موافقته.",
          "romanization": "Taḥaddath maʿa al-mudīr. Sataḥtāj ilā muwāfaqatihi.",
          "korean": "사장님과 얘기하세요. 승인이 필요해요."
        },
        {
          "arabic": "الموعد النهائي يوم الجمعة القادم.",
          "romanization": "Al-mawʿid an-nihā'ī yawm al-jumʿa al-qādim.",
          "korean": "마감일은 다음 금요일이에요."
        }
      ]
    },
    {
      "speaker": "A",
      "variants": [
        {
          "arabic": "عمل جماعي رائع! أحسنتم!",
          "romanization": "ʿAmal jamāʿī rā'iʿ! Aḥsantum!",
          "korean": "훌륭한 팀워크예요! 잘했어요!"
        },
        {
          "arabic": "دعونا نحتفل بنجاح المشروع!",
          "romanization": "Daʿūnā naḥtafil binajāḥ al-mashrūʿ!",
          "korean": "프로젝트 성공을 축하해요!"
        },
        {
          "arabic": "أتمنى لكم عطلة نهاية أسبوع سعيدة!",
          "romanization": "Atamannā lakum ʿuṭlat nihāyat usbūʿ saʿīda!",
          "korean": "즐거운 주말 보내세요!"
        }
      ]
