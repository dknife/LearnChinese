        {
          "arabic": "هل تريد أن نلعب معاً؟",
          "romanization": "Hal turīd an nalʿab maʿan?",
          "korean": "같이 할래요?"
        }
      ]
    },
    {
      "speaker": "B",
      "variants": [
        {
          "arabic": "زرت تركيا. كانت رائعة!",
