        {
          "arabic": "ممتاز! سأكون هناك. مع السلامة!",
          "romanization": "Mumtāz! Sa'akūn hunāk. Maʿa as-salāma!",
          "korean": "좋아요! 갈게요. 안녕히 계세요!"
        }
